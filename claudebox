#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="claudebox"
# Mount the project at its real host path (not /workspace) so Claude inside the
# container stores sessions under the same ~/.claude/projects/<path> folder as a
# native `claude` run — letting both resume each other's chats.
CONTAINER_WORKDIR="$(pwd)"
FORWARD_SSH=false
DO_BUILD=false
BUILD_WITH=""
# LAN egress is blocked by default; the container reaches the internet but not
# your local network. Docker access is off by default: --docker starts an
# isolated rootless daemon inside the box (safe), while --host-docker mounts the
# host socket (effectively host root — lets the container escape the sandbox).
BLOCK_LAN=true
RUN_DIND=false
MOUNT_DOCKER_SOCK=false
PORT_ARGS=()
CLAUDE_ARGS=()

# Available optional tools
ALL_TOOLS="go,python,rust"

print_help() {
    cat <<'EOF'
claudebox — run Claude Code in a sandboxed Docker container.

Usage:
  claudebox [claudebox flags] [claude flags]

By default the container can reach the internet but not your local network,
and has no Docker access. Any flags not listed below are passed through to
Claude Code (e.g. --resume, --model, --print, --dangerously-skip-permissions).

claudebox flags:
  --docker             Start an isolated rootless Docker daemon inside the
                       container (safe; your host's Docker is untouched).
  --host-docker        Mount the host Docker socket. DANGEROUS: effectively host
                       root — escapes the sandbox and bypasses the LAN firewall.
                       Use only when you need the host's daemon.
  --allow-lan          Allow the container to reach your local network
                       (the LAN firewall is on by default).
  --ssh                Forward your local SSH agent for git over SSH.
  -p, --port <h:c>     Publish a container port to your host (repeatable).
  --build              (Re)build the image before launching.
  --with <list>        With --build, include only these optional languages:
                       go, python, rust (comma-separated).
  -h, --help           Show this help and exit.
EOF
}

# Parse claudebox-specific flags, collect the rest for claude
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            print_help
            exit 0
            ;;
        --build)
            DO_BUILD=true
            shift
            ;;
        --with)
            BUILD_WITH="$2"
            shift 2
            ;;
        --ssh)
            FORWARD_SSH=true
            shift
            ;;
        --allow-lan)
            BLOCK_LAN=false
            shift
            ;;
        --docker)
            RUN_DIND=true
            shift
            ;;
        --host-docker)
            MOUNT_DOCKER_SOCK=true
            shift
            ;;
        -p|--port)
            PORT_ARGS+=(-p "$2")
            shift 2
            ;;
        *)
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

# Build the image if requested
if [[ "$DO_BUILD" == true ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    BUILD_ARGS=()

    if [[ -n "$BUILD_WITH" ]]; then
        # Disable all optional tools, then enable only the ones specified
        for tool in ${ALL_TOOLS//,/ }; do
            BUILD_ARGS+=(--build-arg "INSTALL_${tool^^}=false")
        done
        for tool in ${BUILD_WITH//,/ }; do
            BUILD_ARGS+=(--build-arg "INSTALL_${tool^^}=true")
        done
    fi

    echo "Building claudebox image..." >&2
    docker build ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"} -t "$IMAGE_NAME" "$SCRIPT_DIR"
    echo "Build complete." >&2
fi

if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    echo "claudebox image not found. Building..." >&2
    docker build -t "$IMAGE_NAME" "$SCRIPT_DIR"
    echo "Build complete." >&2
fi

# Collect volumes to mount. No fixed --name: Docker assigns a unique name so
# claudebox can run multiple times (even in the same folder) without conflicts.
DOCKER_ARGS=(
    --rm
    -v "$(pwd):${CONTAINER_WORKDIR}"
    -w "${CONTAINER_WORKDIR}"
)

# Forward port mappings
if [[ ${#PORT_ARGS[@]} -gt 0 ]]; then
    DOCKER_ARGS+=("${PORT_ARGS[@]}")
fi

# Block egress to the local network. NET_ADMIN lets the entrypoint install the
# firewall rules; the entrypoint then drops the capability before launching
# Claude so it can't undo them.
if [[ "$BLOCK_LAN" == true ]]; then
    DOCKER_ARGS+=(--cap-add=NET_ADMIN -e CLAUDEBOX_BLOCK_LAN=true)
fi

# Run an isolated, rootless Docker daemon inside the container (--docker). It
# needs unconfined seccomp/apparmor to set up its user namespaces, but NOT
# --privileged or host root, so the sandbox boundary holds.
if [[ "$RUN_DIND" == true ]]; then
    DOCKER_ARGS+=(
        -e CLAUDEBOX_DIND=true
        --security-opt seccomp=unconfined
        --security-opt apparmor=unconfined
    )
fi

# Forward SSH agent if requested and available
if [[ "$FORWARD_SSH" == true ]]; then
    if [[ "$(uname)" == "Darwin" ]]; then
        # Docker Desktop proxies the host SSH agent at this fixed path. The real
        # macOS $SSH_AUTH_SOCK lives outside the Linux VM and can't be mounted.
        DOCKER_ARGS+=(-v /run/host-services/ssh-auth.sock:/tmp/ssh-agent.sock -e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    elif [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        DOCKER_ARGS+=(-v "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock" -e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    else
        echo "Warning: --ssh passed but SSH_AUTH_SOCK is not set." >&2
    fi
fi

# Forward the Anthropic API key if set
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    DOCKER_ARGS+=(-e "ANTHROPIC_API_KEY")
fi

# Forward Claude config directory so settings/memory persist
CLAUDE_CONFIG_DIR="${HOME}/.claude"
if [[ -d "$CLAUDE_CONFIG_DIR" ]]; then
    DOCKER_ARGS+=(-v "${CLAUDE_CONFIG_DIR}:/root/.claude")
fi

# Forward Claude config file (.claude.json) if it exists
CLAUDE_CONFIG_FILE="${HOME}/.claude.json"
if [[ -f "$CLAUDE_CONFIG_FILE" ]]; then
    DOCKER_ARGS+=(-v "${CLAUDE_CONFIG_FILE}:/root/.claude.json")
fi

# On macOS, Claude Code stores the OAuth credential in the Keychain rather than a
# file, so the Linux container has no credentials and reports "not logged in".
# Read the Keychain credential (the full JSON blob, incl. refresh token) and
# forward it as an env var *by name* — so the value never lands on the host disk
# or in the process list. The container's entrypoint writes it to
# ~/.claude/.credentials.json. On Linux hosts the credential is already a file in
# the mounted ~/.claude, so this is skipped.
if [[ "$(uname)" == "Darwin" ]]; then
    if CLAUDEBOX_CREDENTIALS="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)" \
        && [[ -n "$CLAUDEBOX_CREDENTIALS" ]]; then
        export CLAUDEBOX_CREDENTIALS
        DOCKER_ARGS+=(-e CLAUDEBOX_CREDENTIALS)
    else
        echo "Warning: could not read Claude credentials from the macOS Keychain." >&2
    fi
fi

# Forward the host Docker socket so the container can drive the host's daemon
# (--host-docker). Opt-in because socket access is effectively root on the host
# and lets the container escape the sandbox (and bypass the LAN firewall). Use
# --docker instead for an isolated daemon unless you specifically need the host's.
DOCKER_SOCK="/var/run/docker.sock"
if [[ "$MOUNT_DOCKER_SOCK" == true ]]; then
    if [[ -S "$DOCKER_SOCK" ]]; then
        DOCKER_ARGS+=(-v "${DOCKER_SOCK}:/var/run/docker.sock")
    else
        echo "Warning: --host-docker passed but $DOCKER_SOCK not found." >&2
    fi
fi

# Allocate a TTY if stdin is a terminal (interactive use)
if [ -t 0 ]; then
    DOCKER_ARGS+=(-it)
fi

# Warn whenever a flag weakens the sandbox boundary
if [[ "$BLOCK_LAN" != true ]]; then
    echo "⚠️  --allow-lan: the container can reach your local network (LAN, router, metadata endpoints)." >&2
fi
if [[ "$MOUNT_DOCKER_SOCK" == true ]]; then
    echo "⚠️  --host-docker: the host Docker socket is mounted. This grants effective host root and lets the" >&2
    echo "    container escape the sandbox and bypass the LAN firewall. Only use with trusted sessions." >&2
fi
if [[ "$RUN_DIND" == true ]]; then
    echo "🐳 --docker: starting an isolated rootless Docker daemon inside the container (host Docker untouched)." >&2
fi

exec docker run "${DOCKER_ARGS[@]}" "$IMAGE_NAME" ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
